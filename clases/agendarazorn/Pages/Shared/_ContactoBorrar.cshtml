@model AgendaRazorHtmx.Models.Contacto?

<article id="detalle">
    <header>
        <strong>Borrar contacto</strong>
    </header>

    @if (Model is null) {
        <p>Contacto no encontrado.</p>
    }
    else {
        <p>
            Seguro que queres borrar a
            <strong>@Model.Nombre @Model.Apellido</strong>?
        </p>

        <div class="acciones">
            <button class="contrast"
                    hx-post="/Index?handler=Borrar&id=@Model.Id"
                    hx-target="#contactos"
                    hx-swap="innerHTML"
                    hx-confirm="Confirmas el borrado?">
                Si, borrar
            </button>

            <button type="button"
                    class="secondary"
                    hx-get="/Index?handler=Detalle&id=@Model.Id"
                    hx-target="#detalle"
                    hx-swap="outerHTML">
                Cancelar
            </button>
        </div>
    }
</article>