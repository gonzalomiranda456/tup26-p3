@model AgendaRazorHtmx.Models.Contacto?

<article id="detalle">
    <header>
        <strong>Detalle</strong>
    </header>

    @if (Model is null) {
        <p>Contacto no encontrado.</p>
    } else {
        <dl>
            <dt>Nombre</dt>
            <dd>@Model.Nombre</dd>

            <dt>Apellido</dt>
            <dd>@Model.Apellido</dd>

            <dt>Telefono</dt>
            <dd>@Model.Telefono</dd>

            <dt>Email</dt>
            <dd>@Model.Email</dd>

            <dt>Direccion</dt>
            <dd>@Model.Direccion</dd>
        </dl>

        <div class="acciones">
            <button hx-get="/Index?handler=Editar&id=@Model.Id"
                    hx-target="#detalle"
                    hx-swap="outerHTML">
                Editar
            </button>

            <button class="secondary"
                    hx-get="/Index?handler=Borrar&id=@Model.Id"
                    hx-target="#detalle"
                    hx-swap="outerHTML">
                Borrar
            </button>
        </div>
    }
</article>